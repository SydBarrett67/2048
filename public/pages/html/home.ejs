<!DOCTYPE html>
<html lang="it">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= titolo %></title>
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="/pages/style/themes/themes.css">
        <link rel="stylesheet" href="/pages/style/home.css">
    </head>
    <body>

        <!-- HEADER -->
        <header>
            <h1><%= titolo %></h1>
            <p class="subtitle">Unisci i numeri — arriva a <strong style="color:var(--accent)">2048</strong></p>
        </header>

        <!-- PUNTEGGIO -->
        <div class="score-bar">
            <div class="score-box">
                <div class="label">Punteggio</div>
                <div class="value"><%= score %></div>
            </div>
            <div class="score-box">
                <div class="label">Record</div>
                <div class="value"><%= record %></div>
            </div>
            <div class="score-box">
                <div class="label">Mosse</div>
                <div class="value"><%= moves %></div>
            </div>
            <div class="score-box score-box-timer">
                <div class="label">Tempo</div>
                <div class="value">00:00</div>
            </div>
        </div>

        <!-- SELETTORE GRIGLIA -->
        <div class="grid-size-selector">
            <span>Griglia:</span>
            <button class="grid-size-btn <%= gridSize === 3 ? 'active' : '' %>" data-size="3">3×3</button>
            <button class="grid-size-btn <%= gridSize === 4 ? 'active' : '' %>" data-size="4">4×4</button>
            <button class="grid-size-btn <%= gridSize === 5 ? 'active' : '' %>" data-size="5">5×5</button>
        </div>

        <!-- GRIGLIA -->
        <div class="board-wrapper">
            <div class="board" data-size="<%= gridSize %>">
                <% grid.forEach(function(val) { %>
                    <% if (val === 0) { %>
                        <div class="tile tile-empty"></div>
                    <% } else { %>
                        <div class="tile tile-<%= val %>"><%= val %></div>
                    <% } %>
                <% }) %>
            </div>
        </div>

        <!-- AZIONI -->
        <div class="actions">
            <% if (playing) { %>
                <button class="btn btn-primary" id="btn-continua">▶ CONTINUA PARTITA</button>
                <button class="btn btn-secondary" id="btn-nuova">↺ NUOVA PARTITA</button>
            <% } else { %>
                <button class="btn btn-primary" id="btn-nuova">▶ NUOVA PARTITA</button>
            <% } %>
        </div>

        <!-- CLASSIFICA -->
        <div class="best-scores">
            <h2>★ MIGLIORI PUNTEGGI</h2>
            <% leaderboard.forEach(function(entry, i) { %>
                <div class="score-row">
                    <span class="rank">#<%= i + 1 %></span>
                    <span class="player"><%= entry.nome %></span>
                    <span class="pts"><%= entry.punteggio.toLocaleString('it-IT') %></span>
                    <span class="tempo">
                        <%= Math.floor(entry.tempo / 60) %>m <%= entry.tempo % 60 %>s
                    </span>
                </div>
            <% }) %>
        </div>

        <!-- USER AREA -->
        <% if (userLoggedIn) { %>
            <script>window.USERNAME = "<%= user.nome %>";</script>
            <div class="user-area">
                <img class="avatar" src="<%= user.avatar || '/img/default-avatar.png' %>" alt="<%= user.nome %>" />
                <span class="username"><%= user.nome %></span>
                <div class="hamburger" id="btn-hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
            

            <div class="hamburger-menu" id="hamburger-menu">
                <a href="/storico">Storico partite</a>
                <div class="theme-selector">
                    <span>Temi:</span>
                    <button class="theme-btn" data-theme="light">☀️</button>
                    <button class="theme-btn" data-theme="dark">🌙</button>
                    <button class="theme-btn" data-theme="colorful">🎨</button>
                    <button class="theme-btn" data-theme="syds-choice">🎵</button>
                </div>
                <a href="#" id="btn-logout">⏻ Logout</a>
            </div>
        <% } else { %>
            <a href="/login" class="btn-login-fixed">▶ LOGIN</a>
        <% } %>

        <script>window.THEME = "<%= theme %>";</script>
        <script src="/pages/js/home.js"></script>
    </body>
</html>
